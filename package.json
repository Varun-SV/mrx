{
  "name": "mrx-ai",
  "version": "0.1.3",
  "description": "Multi-role model orchestration CLI — assign different LLMs to reasoning, execution, and tool-calling roles",
  "type": "module",
  "main": "./dist/cli/index.js",
  "files": [
    "dist/",
    "CHANGELOG.md",
    "LICENSE",
    "README.md"
  ],
  "bin": {
    "mrx": "./dist/cli/index.js"
  },
  "scripts": {
    "build": "tsc && node -e \"require('node:fs').chmodSync('dist/cli/index.js', 0o755)\"",
    "dev": "tsx src/cli/index.ts",
    "start": "node dist/cli/index.js",
    "test": "npm run test:unit && npm run test:release",
    "test:unit": "node --experimental-vm-modules node_modules/.bin/jest",
    "test:release": "node --test tests/release/*.test.mjs",
    "test:watch": "node --experimental-vm-modules node_modules/.bin/jest --watch",
    "test:coverage": "node --experimental-vm-modules node_modules/.bin/jest --coverage && npm run test:release",
    "lint": "eslint src tests scripts --ext .ts,.tsx,.mjs",
    "lint:fix": "eslint src tests scripts --ext .ts,.tsx,.mjs --fix",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.{ts,mjs}\" \"scripts/**/*.mjs\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"tests/**/*.{ts,mjs}\" \"scripts/**/*.mjs\"",
    "release:check": "node scripts/check-release.mjs",
    "pack:check": "npm pack --dry-run",
    "prepack": "npm run build"
  },
  "keywords": ["llm", "cli", "multi-model", "orchestration", "ai", "reasoning"],
  "author": "Varun-SV",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Varun-SV/mrx.git"
  },
  "homepage": "https://github.com/Varun-SV/mrx#readme",
  "bugs": {
    "url": "https://github.com/Varun-SV/mrx/issues"
  },
  "packageManager": "npm@11.16.0",
  "engines": {
    "node": ">=22.12.0"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^0.0.50",
    "@ai-sdk/google": "^0.0.50",
    "@ai-sdk/openai": "^0.0.60",
    "ai": "^3.4.0",
    "better-sqlite3": "^12.11.1",
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "execa": "^9.3.0",
    "ink": "^4.4.1",
    "js-yaml": "^4.1.0",
    "node-fetch": "^3.3.2",
    "ollama-ai-provider": "^0.15.0",
    "ora": "^8.1.0",
    "react": "^18.3.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/jest": "^29.5.12",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.1",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.1",
    "jest": "^29.7.0",
    "prettier": "^3.3.3",
    "semver": "^7.7.2",
    "ts-jest": "^29.2.3",
    "tsx": "^4.11.0",
    "typescript": "^5.4.0"
  }
}
