{
  "name": "mrx",
  "version": "0.1.0",
  "description": "Multi-role model orchestration CLI — assign different LLMs to reasoning, execution, and tool-calling roles",
  "type": "module",
  "main": "./dist/cli/index.js",
  "bin": {
    "mrx": "./dist/cli/index.js"
  },
  "scripts": {
    "build": "tsc && chmod +x dist/cli/index.js",
    "dev": "tsx src/cli/index.ts",
    "start": "node dist/cli/index.js",
    "test": "node --experimental-vm-modules node_modules/.bin/jest",
    "test:watch": "node --experimental-vm-modules node_modules/.bin/jest --watch",
    "test:coverage": "node --experimental-vm-modules node_modules/.bin/jest --coverage",
    "lint": "eslint src tests",
    "lint:fix": "eslint src tests --fix",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"tests/**/*.ts\""
  },
  "keywords": ["llm", "cli", "multi-model", "orchestration", "ai", "reasoning"],
  "author": "Varun-SV",
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^0.0.50",
    "@ai-sdk/google": "^0.0.50",
    "@ai-sdk/openai": "^0.0.60",
    "ai": "^3.4.0",
    "better-sqlite3": "^11.1.2",
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "execa": "^9.3.0",
    "ink": "^4.4.1",
    "js-yaml": "^4.1.0",
    "node-fetch": "^3.3.2",
    "ollama-ai-provider": "^0.15.0",
    "ora": "^8.1.0",
    "react": "^18.3.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/jest": "^29.5.12",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.0.0",
    "@types/react": "^18.3.1",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.1",
    "jest": "^29.7.0",
    "prettier": "^3.3.3",
    "ts-jest": "^29.2.3",
    "tsx": "^4.11.0",
    "typescript": "^5.4.0"
  }
}
